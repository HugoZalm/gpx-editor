{
  "name": "frontend",
  "version": "0.1.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "compodoc": "npx @compodoc/compodoc -p tsconfig.doc.json",
    "github:build:1": "ng build --configuration production --output-path docs --base-href /gpx-editor/",
